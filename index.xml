      <metadata>
        <description><![CDATA[{\rtf1\ansi\deff0{\fonttbl{\f0 \fswiss Helvetica;}{\f1 \fmodern Courier;}}
{\colortbl;\red255\green0\blue0;\red0\green0\blue255;}
\widowctrl\hyphauto

{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel0 \b \fs36 DM Batch Renamer\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Batch renaming tool for REAPER with live preview.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 Features\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Rename {\b items, tracks, regions, and markers} in batch\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Live preview table before applying changes\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Find/Replace with {\b Lua pattern} support\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Prefix, Suffix, Case transformations (9 modes)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Replace spaces (underscore, dash, remove)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Increment mode (number or letter sequences)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab {\b Folder Items} tab with custom naming patterns ($region, $track, $position, $index)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Preset system to save/load renaming configurations\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Inline editing directly in the preview table\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Customizable appearance (colors, scale, theme presets)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Companion scripts for region/marker click-selection\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 Requirements\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab {\field{\*\fldinst{HYPERLINK "https://forum.cockos.com/showthread.php?t=250419"}}{\fldrslt{\ul
ReaImGui
}}}
 (installed automatically via ReaPack)\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Optional: {\field{\*\fldinst{HYPERLINK "https://www.sws-extension.org/"}}{\fldrslt{\ul
SWS Extension
}}}
 for region/marker click-selection\sa180\par}
}
]]></description>
